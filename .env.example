# Orsia Vercel Environment Variables
# ─────────────────────────────────────────────────────────────
# Add these in Vercel dashboard: Project → Settings → Environment Variables
# NEVER commit actual values to GitHub
# ─────────────────────────────────────────────────────────────

# Your Shopify store myshopify URL (no https://)
SHOPIFY_STORE=orsia-jewellery.myshopify.com

# Your Shopify store domain for CORS (no https://)
SHOPIFY_STORE_DOMAIN=orsia-jewellery.myshopify.com

# From Dev Dashboard → Settings → Credentials → Client ID
SHOPIFY_CLIENT_ID=ffda82e668e4e93b906140eda4310dce

# From Dev Dashboard → Settings → Credentials → Secret (shpss_...)
SHOPIFY_CLIENT_SECRET=shpss_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
