# Orsia Vercel Environment Variables
# ─────────────────────────────────────────────────────────────
# Copy this file, rename to .env, and fill in your values.
# NEVER commit .env to GitHub — it contains secret keys.
# Add these same values in Vercel dashboard under:
# Project → Settings → Environment Variables
# ─────────────────────────────────────────────────────────────

# Your Shopify store URL (no https://)
# Example: orsia-jewels.myshopify.com
SHOPIFY_STORE=your-store.myshopify.com

# Your Shopify store domain (used for CORS — your actual domain)
# Example: www.orsiajewels.com OR orsia-jewels.myshopify.com
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com

# Shopify Admin API access token
# Get from: Shopify Admin → Settings → Apps → Develop apps
# Required scopes: read_products, write_draft_orders, read_metafields
# Starts with: shpat_
SHOPIFY_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
